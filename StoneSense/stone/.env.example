# Firebase Service Account
# Place your serviceAccountKey.json file in the root directory

# OpenRouter API Key
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your api key"

# Twilio Configuration for WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Base URL for serving PDFs (use ngrok URL for local testing)
# Example: https://abc123.ngrok.io
# Leave empty to send message without PDF attachment
BASE_URL=

# Note: For WhatsApp media attachments, you'll need a publicly accessible URL
# Run `ngrok http 5001` and copy the HTTPS URL to BASE_URL above